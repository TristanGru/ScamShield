# ─────────────────────────────────────────────────────────────
# ScamShield Dashboard — Environment Variables
# Copy to dashboard/.env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Auth0 (https://auth0.com/docs/quickstart/webapp/nextjs)
AUTH0_SECRET=use-openssl-rand-hex-32-to-generate-this
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id_here
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here

# Pi API URL — server-side only, never exposed to browser
# Dev: http://localhost:8000
# Prod: https://your-ngrok-subdomain.ngrok-free.app
PI_API_URL=http://localhost:8000
