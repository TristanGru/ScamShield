# ─────────────────────────────────────────────────────────────
# ScamShield Pi — Environment Variables
# Copy this file to pi/.env and fill in all values.
# NEVER commit pi/.env to git.
#
# Must set (real values, not placeholders):
#   GEMINI_API_KEY
#   ELEVENLABS_API_KEY
#   TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM_NUMBER, TWILIO_TO_NUMBER
# Often set for demo / dashboard:
#   POSTGRES_URL, NGROK_AUTHTOKEN
# Nest audio over LAN (if needed):
#   NEST_IP — Chromecast target; PI_LAN_IP / PI_API_PORT — URL the Nest uses to fetch warning.mp3
# ─────────────────────────────────────────────────────────────

# Gemini API (required)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional — scam detection model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ElevenLabs (API key required; voice defaults if omitted)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default premade voice "Adam" male (free-tier API — not a Voice Library marketplace ID):
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Female premade alternative: Rachel = 21m00Tcm4TlvDq8ikWAM
# Omit the line above entirely to use the same default in code, or override with any voice ID
# from GET https://api.elevenlabs.io/v1/voices (see pi/list_elevenlabs_voices.py).
# No spaces in the ID — strip them if you pasted from elsewhere.
# Optional: different voice for the Nest warning only (defaults to ELEVENLABS_VOICE_ID)
# ELEVENLABS_WARNING_VOICE_ID=another_voice_id_here
# Optional model / format (defaults work for most setups)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
#
# FREE TIER: HTTP 402 "paid_plan_required" applies to Voice *Library* (marketplace) voices.
# Premade voices (e.g. Adam, Rachel) work via API; library voices need a paid plan or use gTTS fallback.
# After changing voice/model: delete pi/warning.mp3 and pi/warning.mp3.meta, or set once:
# ELEVENLABS_REGENERATE_WARNING=1
# To force Google TTS instead of ElevenLabs (sounds like default Google, not your EL voice):
# ELEVENLABS_SKIP_WARNING=1

# Twilio SMS (required)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+1XXXXXXXXXX

# Database (SQLite is local on the Pi; set path you use — e.g. ./scamshield.db under pi/ for dev)
SQLITE_DB_PATH=/data/scamshield.db
POSTGRES_URL=postgresql://user:password@host:5432/scamshield

# ngrok (for remote dashboard access during hackathon)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Optional: Nest/Chromecast LAN IP if mDNS discovery fails on the Pi (reduces pychromecast/zeroconf issues)
# NEST_IP=192.168.1.50

# Pi's own LAN IP — Chromecast loads http://PI_LAN_IP:PI_API_PORT/warning.mp3 (must match FastAPI bind port).
# Auto-detected if not set; set PI_LAN_IP if the Pi picks the wrong interface.
# PI_LAN_IP=192.168.1.100
# PI_API_PORT=8000

# Skip Chromecast discovery entirely (use if zeroconf/pychromecast crashes on the Pi; alerts still work minus Nest audio)
# SKIP_NEST_DISCOVERY=1

# Text-only mode: no ElevenLabs API, Nest, or SenseCAP serial — logs/prints what each would send (dev/demo)
# SCAMSHIELD_TEXT_ONLY=1

# ── Testing / dev safety switches ─────────────────────────────────────────────
# Skip Twilio SMS entirely (no charges, no real messages sent)
# SCAMSHIELD_SKIP_SMS=1
# Skip Grove buzzer on alerts (LED still turns red)
# SCAMSHIELD_SKIP_BUZZER=1
# Skip Gemini API calls and use keyword-only scoring (no API quota used)
# SCAMSHIELD_SKIP_GEMINI=1

# Audio device (run `python -c "import pyaudio; p=pyaudio.PyAudio(); [print(i, p.get_device_info_by_index(i)['name']) for i in range(p.get_device_count())]"` to find index)
AUDIO_DEVICE_INDEX=0
VAD_THRESHOLD=500
CHUNK_DURATION_SECONDS=15

# Grove HAT GPIO pin assignments (BCM numbering)
# D5  → GPIO 5  — Grove Button
# D16 → GPIO 16 — Grove Buzzer
# A0  → channel 0 — Grove Sound Sensor (analog, read via HAT ADC)
GPIO_LED_RED_PIN=24
GPIO_LED_GREEN_PIN=23
GPIO_BUZZER_PIN=16
GPIO_BUTTON_PIN=5
GPIO_SOUND_SENSOR_PIN=0

# SenseCAP Indicator serial port (check with `ls /dev/ttyUSB*` or `ls /dev/ttyACM*`)
SENSECAP_SERIAL_PORT=/dev/ttyUSB0
SENSECAP_BAUD_RATE=115200

# Detection tuning
SCAM_SCORE_THRESHOLD=75
SCAM_KEYWORD_MIN_MATCHES=2
SMS_DEBOUNCE_SECONDS=60
# Seconds between full alerts (Nest/buzzer/SMS); DB writes still happen during cooldown
SCAM_ALERT_COOLDOWN=30
# Number of recent transcript chunks sent to Gemini for conversation context (reduces false positives)
SCAM_CONTEXT_CHUNKS=5
# Clear transcript buffer after N consecutive empty transcripts (~silence = new call)
SCAM_CONTEXT_SILENCE_RESET=3
# Nest audio: Gemini writes spoken script from conversation context, then ElevenLabs TTS (1 = on)
# SCAM_DYNAMIC_NEST_VOICE=1
